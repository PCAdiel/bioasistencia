# Supabase → Connect → Transaction pooler (serverless, puerto 6543)
DATABASE_URL=postgresql://postgres.PROJECT_REF:CLAVE@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require

# Genere secretos independientes. Nunca los publique.
JWT_SECRET=reemplace-por-un-secreto-aleatorio-de-32-o-mas-caracteres
BIOMETRIC_ENCRYPTION_KEY=reemplace-por-32-bytes-en-base64

# Ajustable después de calibrar con pruebas reales.
FACE_MATCH_THRESHOLD=0.58
NEXT_PUBLIC_APP_NAME=Asistencia Biométrica
